- Take the information of vms and its kvm host from Dora

- Take backup of fstab on all vms

  ansible -i vmlist all -b -m copy -a 'src=/etc/fstab dest=/etc/fstab.bak remote_src=yes'

- Update ramdisk size to 28GB on all vms

  ansible -i vmlist all -b -m lineinfile -a 'path=/etc/fstab regexp="^tmpfs\s+/mnt/ramdisk" line="tmpfs /mnt/ramdisk tmpfs defaults,size=28G 0 0"'

  ansible -i vmlist all -m shell -a 'cat /etc/fstab'

