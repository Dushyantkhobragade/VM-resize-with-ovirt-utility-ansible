---
- hosts: localhost
  connection: local
  gather_facts: false
  
  vars_prompt:
    - name: CSV_PATH
      prompt: "Enter the path of CSV file of VMs. Exa: /home/dushyantk/vm.csv"
      private: no

  tasks:
    - name: Login to Ovirt
      ovirt.ovirt.ovirt_auth:  
        url: https://dushyantlab.io/ovirt-engine/api
        username: admin@internal
        password: 123456
        insecure: true

    - name: Read VM metada information
      read_csv:
        path: "{{ CSV_PATH }}"
      register: vm_metadata
      delegate_to: localhost

    - name: Display VM Metadata information
      debug: 
        var: vm_metadata.list

    - name: Review VM Metadata Information Before Moving to Next task of VM Resize
      pause:
        prompt: Please see the VM list?. Do you want to continue! Press return to continue. Press Ctrl+c and then "a" to abort.
     
    - name: Power off the requested VMs
      ovirt.ovirt.ovirt_vm:
        name: "{{ item.VMNAME }}"
        auth: "{{ ovirt_auth }}"
        state: stopped
        wait: true
      loop: "{{ vm_metadata.list }}"

    - name: Modify memory size on requested VMs
      ovirt.ovirt.ovirt_vm:
        auth: "{{ ovirt_auth }}"
        name: "{{ item.VMNAME }}"
        memory: "{{ item.MEMORY }}"
        memory_guaranteed: "{{ item.MEMORY }}"
        cpu_cores: "{{ item.CPU_Cores }}"
        cpu_sockets: "{{ item.CPU_Socket }}"
        wait: true
      loop: "{{ vm_metadata.list }}"

    - name: "Run VM {{ item.VMNAME }} on {{ item.KVM_Host }}"
      ovirt.ovirt.ovirt_vm:
        name:  "{{ item.VMNAME }}"
        auth: "{{ ovirt_auth }}"
        state: running
        host: "{{ item.KVM_Host }}" 
        wait: true
      loop: "{{ vm_metadata.list }}"
      loop_control:
        label: "{{ item.VMNAME }} → {{ item.KVM_Host }}"

    - name: ALogout from Oracle Hosted Engine
      ovirt_auth:
        state: absent
        ovirt_auth: "{{ ovirt_auth }}"
